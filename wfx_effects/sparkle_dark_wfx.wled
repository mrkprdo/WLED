// Sparkle Dark — Dark background with a single white sparkle pixel
// that randomly jumps to a new position each frame.

effect "Sparkle Dark WFX" {
  meta {
    slider speed "Speed"
    slider intensity "Brightness"
  }

  render {
    fill(rgb(0, 0, 0))

    let pos = random(LEN)
    let bri = intensity
    if bri < 64 {
      bri = 64
    }
    pixel(pos, rgb(bri, bri, bri))

    frame(speed)
  }
}
