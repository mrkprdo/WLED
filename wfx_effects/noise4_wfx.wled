// Noise 4 — Fast noise pattern driven by speed and time.
// C++ original: stp = (now*speed)>>7, inoise8(i<<12, stp), palette(index).

effect "Noise 4 WFX" {
  meta {
    slider speed "Speed"
    palette true
  }

  render {
    let stp = NOW * speed / 128

    for i in 0..LEN {
      let idx = noise2(i * 4096, stp)
      pixel(i, palette(idx))
    }

    frame(16)
  }
}
