// Fill Noise — Fill with Perlin noise-based colors from palette.
// C++ original: inoise8(i*SEGLEN, step+i*SEGLEN), step += beatsin8(speed,1,6).

effect "Fill Noise WFX" {
  meta {
    slider speed "Speed"
    palette true
  }

  render {
    if CALL == 0 {
      step_val = random(0, 256)
    }

    for i in 0..LEN {
      let idx = noise2(i * LEN, step_val + i * LEN)
      pixel(i, palette(idx))
    }

    step_val = step_val + beat8(speed, 1, 6)

    frame(16)
  }
}
