effect "Chase WFX" {
  meta {
    slider speed "Speed"
    slider intensity "Width"
    palette true
  }

  render {
    let width = max(intensity / 16, 1)
    let pos = (NOW * speed / 512) % LEN

    fill(rgb(0, 0, 0))

    for j in 0..width {
      let idx = (pos + j) % LEN
      pixel(idx, palette(j * 255 / width))
    }

    frame(speed)
  }
}
